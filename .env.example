# ============================================
# PeabiruJobs — variáveis de ambiente
# Copie para .env.local e preencha os valores.
# ============================================

# Supabase (obrigatório) — Painel do projeto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Provider de IA (opcional)
# "mock"      → gera análise simulada realista (padrão, não precisa de chave)
# "anthropic" → usa a API da Anthropic (requer ANTHROPIC_API_KEY)
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
